# ---- LLM ----
LLM_PROVIDER=openai
OPENAI_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0

# ---- Retrieval ----
TOP_K=10
MAX_CONTEXT_CHUNKS=5
HISTORY_TURNS=5

GRAPH_TOP_K=5
HYBRID_VECTOR_WEIGHT=0.75
HYBRID_GRAPH_WEIGHT=0.25

# ---- Rerank ----
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_N=5

# ---- Graph ----
GRAPH_ENABLED=true
GRAPH_PROVIDER=neo4j
GRAPH_URI=bolt://localhost:7687
GRAPH_USER=neo4j
GRAPH_PASSWORD=your_password
GRAPH_DATABASE=neo4j

GRAPH_BUILD_ENABLED=true
GRAPH_MAX_RELATION_HOPS=2
GRAPH_ENTITY_MIN_CONFIDENCE=0.70
GRAPH_RELATION_MIN_CONFIDENCE=0.75
GRAPH_ENABLE_SECTION_NODES=true

# ---- GraphRAG KG Build ----
GRAPH_EXTRACTOR=neo4j_graphrag
GRAPH_LLM_PROVIDER=openai
GRAPH_LLM_MODEL=gpt-4o-mini
GRAPH_LLM_TEMPERATURE=0
GRAPH_SCHEMA_MODE=EXTRACTED
GRAPH_EMBEDDING_MODEL=text-embedding-3-small
GRAPH_BUILD_BATCH_SIZE=1
GRAPH_SOURCE_LINK_MODE=from_chunk
GRAPH_CLEAN_BEFORE_BUILD=true